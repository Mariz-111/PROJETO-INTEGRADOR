-----TABELAS-----

--PRODUTO
CREATE TABLE produto (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  nome TEXT NOT NULL,
  preco DECIMAL(10,2),
  estoque VARCHAR(100),
  descricao TEXT
);

--CUPON
CREATE TABLE cupom (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  codigo VARCHAR(20) UNIQUE,
  desconto DECIMAL(5,2),
  validade DATE
);

--COMPRA
CREATE TABLE compra (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  produto_id INTEGER,
  metodo_pagamento VARCHAR(20),
  status_pagamento VARCHAR(30),
  data_pagamento DATE,
  status_entrega VARCHAR(40),
  frete DECIMAL(10,2),
  cupom_id INTEGER,
  quantidade INTEGER,
  valor_total DECIMAL(10,2),
  FOREIGN KEY (usuario_id) REFERENCES cliente(id),
  FOREIGN KEY (produto_id) REFERENCES produtos(id),
  FOREIGN KEY (cupom_id) REFERENCES cupon(id)
);

--CLIENTE
CREATE TABLE cliente (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  nome TEXT NOT NULL,
  telefone VARCHAR(13),
  cpf TEXT UNIQUE NOT NULL,
  email TEXT UNIQUE NOT NULL,
  senha TEXT
);

--PAGAMENTO
CREATE TABLE forma_de_pagamento (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  tipo_de_pagamento VARCHAR(20)
);


--PEDIDO
CREATE TABLE pedidos (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  cliente_id INTEGER,
  data_pedido DATE,
  pagamento_id INTEGER,
  status_id INTEGER,
  subtotal DECIMAL(6,2),
  frete DECIMAL(6,2),
  FOREIGN KEY (status_id) REFERENCES status_pedido(id),
  FOREIGN KEY (cliente_id) REFERENCES cliente(id),
  FOREIGN KEY (pagamento_id) REFERENCES forma_de_pagamento(id)
);


-----INDEX-----


CREATE INDEX idx_email ON cliente(email);
